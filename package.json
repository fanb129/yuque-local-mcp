{
  "name": "yuque-local-mcp",
  "version": "0.1.0",
  "description": "A local MCP server for controlled Yuque access through your own browser session.",
  "type": "module",
  "bin": {
    "yuque-local-mcp": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "doctor": "tsx src/doctor.ts",
    "login": "node dist/login.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "playwright": "^1.58.2",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
